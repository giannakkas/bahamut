# ─── Bahamut API URL ──────────────────────────────────────────
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (Railway):
# NEXT_PUBLIC_API_URL=https://your-api-service.railway.app

# ─── Mock Mode ────────────────────────────────────────────────
# true = use mock data (no backend needed)
# false = connect to real API (default)
NEXT_PUBLIC_MOCK_MODE=false

# ─── Polling Interval ─────────────────────────────────────────
# Auto-refresh interval in milliseconds (default 5000)
NEXT_PUBLIC_REFRESH_INTERVAL=5000
