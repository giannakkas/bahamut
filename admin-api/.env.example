# ─── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-real-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ─── Admin Credentials ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-frontend.railway.app

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./bahamut.db
# DATABASE_URL=postgresql://user:pass@host:5432/bahamut

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── API Docs ─────────────────────────────────────────────────
# Set to false to disable /docs and /redoc in production
ENABLE_DOCS=true

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
